# Local-only secrets. Copy this file to .env.local and fill in real values.
# In production, configure these as Project Environment Variables in Vercel —
# never commit real keys to git.

# Server-side only. Required for live traffic data; without it, /api/analyze-route
# returns synthesized "demo mode" durations so the UI can be developed offline.
# Enable the Routes API on this key in Google Cloud Console.
GOOGLE_MAPS_API_KEY=AIzaSyD-i83pVPVfJrW86U2-nj-BL0z0AN7lCpE

# Optional. In-memory TTL (seconds) for cached duration lookups, keyed by
# (origin, destination, day-of-week, 10-minute bucket). Defaults to 1200 (20 min).
CACHE_TTL_SECONDS=1200
